{
  "name": "taskr",
  "version": "1.0.0",
  "description": "Task management REST API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:seed": "node db/seed.js",
    "db:reset": "rm -f taskr.db && node db/seed.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/*.test.js",
      "**/tests/userTest.js",
      "**/tests/test-projects.js"
    ]
  }
}
